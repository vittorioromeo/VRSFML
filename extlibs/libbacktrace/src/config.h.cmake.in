/* config.h generated by CMake from config.h.cmake.in */

#cmakedefine BACKTRACE_ELF_SIZE @BACKTRACE_ELF_SIZE@
#cmakedefine BACKTRACE_XCOFF_SIZE @BACKTRACE_XCOFF_SIZE@

/* Function / feature / header probes.
   Upstream libbacktrace tests these with #ifdef / defined(), so an absent
   feature must leave the macro UNDEFINED (not defined to 0). */
#cmakedefine HAVE_ATOMIC_FUNCTIONS 1
#cmakedefine HAVE_CLOCK_GETTIME    1
#cmakedefine HAVE_DLFCN_H          1
#cmakedefine HAVE_DL_ITERATE_PHDR  1
#cmakedefine HAVE_FCNTL            1
#cmakedefine HAVE_GETEXECNAME      1
#cmakedefine HAVE_GETIPINFO        1
#cmakedefine HAVE_INTTYPES_H       1
#cmakedefine HAVE_KERN_PROC        1
#cmakedefine HAVE_KERN_PROC_ARGS   1
#cmakedefine HAVE_LIBLZMA          1
#cmakedefine HAVE_LINK_H           1
#cmakedefine HAVE_LOADQUERY        1
#cmakedefine HAVE_LSTAT            1
#cmakedefine HAVE_MACH_O_DYLD_H    1
#cmakedefine HAVE_MEMORY_H         1
#cmakedefine HAVE_READLINK         1
#cmakedefine HAVE_STDINT_H         1
#cmakedefine HAVE_STDLIB_H         1
#cmakedefine HAVE_STRINGS_H        1
#cmakedefine HAVE_STRING_H         1
#cmakedefine HAVE_SYNC_FUNCTIONS   1
#cmakedefine HAVE_SYS_LDR_H        1
#cmakedefine HAVE_SYS_LINK_H       1
#cmakedefine HAVE_SYS_MMAN_H       1
#cmakedefine HAVE_SYS_STAT_H       1
#cmakedefine HAVE_SYS_TYPES_H      1
#cmakedefine HAVE_TLHELP32_H       1
#cmakedefine HAVE_UNISTD_H         1
#cmakedefine HAVE_WINDOWS_H        1
#cmakedefine HAVE_ZLIB             1
#cmakedefine HAVE_ZSTD             1

/* HAVE_DECL_* macros follow the AC_CHECK_DECLS convention: always defined,
   to 0 when the symbol is absent and to 1 when present. */
#cmakedefine01 HAVE_DECL_GETPAGESIZE
#cmakedefine01 HAVE_DECL_STRNLEN
#cmakedefine01 HAVE_DECL__PGMPTR

#define STDC_HEADERS 1

#ifndef _GNU_SOURCE
# define _GNU_SOURCE 1
#endif

#ifndef _DARWIN_USE_64_BIT_INODE
# define _DARWIN_USE_64_BIT_INODE 1
#endif
